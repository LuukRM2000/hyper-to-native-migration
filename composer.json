{
  "name": "lm2k/craft-hyper-to-link",
  "description": "Migrate Verbb Hyper fields and content to Craft's native Link field with CLI audit and migration commands.",
  "type": "craft-plugin",
  "keywords": [
    "craftcms",
    "craft-plugin",
    "migration",
    "hyper",
    "link",
    "cli"
  ],
  "license": "proprietary",
  "authors": [
    {
      "name": "Luuk Molenbeek",
      "homepage": "https://github.com/LuukRM2000"
    }
  ],
  "homepage": "https://github.com/LuukRM2000/hyper-to-native-migration",
  "support": {
    "issues": "https://github.com/LuukRM2000/hyper-to-native-migration/issues",
    "source": "https://github.com/LuukRM2000/hyper-to-native-migration",
    "docs": "https://github.com/LuukRM2000/hyper-to-native-migration/blob/main/README.md",
    "rss": "https://github.com/LuukRM2000/hyper-to-native-migration/commits/main.atom"
  },
  "require": {
    "php": "^8.2",
    "craftcms/cms": "^5.3"
  },
  "require-dev": {
    "codeception/module-asserts": "^3.2",
    "codeception/module-yii2": "^2.0",
    "codeception/phpunit-wrapper": "^11.0",
    "craftcms/test": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "lm2k\\hypertolink\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "lm2k\\hypertolink\\tests\\": "tests/"
    }
  },
  "extra": {
    "name": "Hyper to Link",
    "handle": "hyper-to-link",
    "description": "CLI-first migration tooling for moving Verbb Hyper fields and content to Craft's native Link field.",
    "class": "lm2k\\hypertolink\\HyperToLink",
    "schemaVersion": "1.0.0",
    "developer": "Luuk Molenbeek",
    "developerUrl": "https://github.com/LuukRM2000",
    "documentationUrl": "https://github.com/LuukRM2000/hyper-to-native-migration/blob/main/README.md",
    "changelogUrl": "https://raw.githubusercontent.com/LuukRM2000/hyper-to-native-migration/main/CHANGELOG.md"
  },
  "scripts": {
    "test": "php vendor/bin/codecept run"
  }
}
